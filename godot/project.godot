; Engine configuration file.
; Varracor 3D - Godot-rinnakkaisversio (top-down 3D, PS5-ohjain pohjana).
; PY-versio (repon juuri) on pelilogiikan totuuslähde; data/ -kansion
; JSONit exportataan sieltä (python tools/export_gamedata.py).

config_version=5

[application]

config/name="Varracor 3D"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3")

[autoload]

InputSetup="*res://scripts/input_setup.gd"
Audio="*res://scripts/audio_director.gd"
Router="*res://scripts/scene_router.gd"
Catalogs="*res://scripts/catalogs.gd"
SaveGame="*res://scripts/save_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

buffering/agile_event_flushing=true

[rendering]

renderer/rendering_method="forward_plus"
