; Engine configuration file.
; Varracor 3D - Godot-rinnakkaisversio (top-down 3D).
; PY-versio (repon juuri) on pelilogiikan totuuslähde; data/ -kansion
; JSONit exportataan sieltä (python tools/export_gamedata.py).

config_version=5

[application]

config/name="Varracor 3D"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3")

[autoload]

Catalogs="*res://scripts/catalogs.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"
